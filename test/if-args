# Test: if with args
# Usage: rt if-args foo bar 42
# args[0] = if-args, args[1] = foo, args[2] = bar, args[3] = 42

print "--- if args == literal (true) ---"
if args[2] == foo
print "OK: args[2] == foo"
end

print "--- if args == literal (false) ---"
if args[1] == bar
print "FAIL: args[1] should not be bar"
end
print "OK: skipped false block"

print "--- if args == args (true) ---"
if args[1] == args[1]
print "OK: args[1] == args[1]"
end

print "--- if args != args (true) ---"
if args[1] != args[2]
print "OK: args[1] != args[2]"
end

print "--- if args numeric < (true) ---"
if args[4] < 100
print "OK: args[4] < 100"
end

print "--- if args numeric > (false) ---"
if args[4] > 100
print "FAIL: args[4] should not be > 100"
end
print "OK: skipped false block"
